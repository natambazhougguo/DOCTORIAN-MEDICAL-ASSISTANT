# APP_URL: The URL where this application is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# JWT Secret for authentication
JWT_SECRET=doctorian_super_secret_key

# MTN Configuration (for MoMo, SMS and Voice)
# 1. Register at MTN Developer Portal
# 2. Get your API Key, User ID, and Subscription Key
MTN_API_KEY=
MTN_MOMO_USER_ID=
MTN_MOMO_API_USER=
MTN_MOMO_SUB_KEY=
MTN_MOMO_ENV=sandbox
MTN_SENDER_ID=DOCTORIAN
MTN_BASE_URL=https://api.mtn.com/v1

# Emergency Contacts (MUST use E.164 format: +256...)
DOCTOR_PHONE_NUMBER=+256787674140
MENTOR_PHONE_NUMBER=

# Twilio Configuration (Alternative for SMS and Voice)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Deepseek R1 API Key (Optional, from OpenRouter)
# If not provided, Gemini will be used as fallback for all AI features
DEEPSEEK_API_KEY=

# Gemini API Key (Required for AI features)
# The system will automatically provide this in the build environment
GEMINI_API_KEY=
API_KEY=

# Email Configuration (for signup/login notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ADMIN_EMAIL=Josephhaxzy@gmail.com
