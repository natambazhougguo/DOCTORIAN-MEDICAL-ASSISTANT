{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile photo URL." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role in the application." },
        "subscriptionTier": { "type": "string", "enum": ["free", "silver", "gold"], "description": "The user's AI performance tier." },
        "subscriptionStatus": { "type": "string", "enum": ["active", "expired", "none"], "description": "Status of the user's subscription." },
        "lastPaymentDate": { "type": "string", "format": "date-time", "description": "Timestamp of the last payment." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The timestamp when the profile was created." }
      },
      "required": ["uid", "email", "role", "createdAt", "subscriptionTier"]
    },
    "HealthRecord": {
      "title": "Health Record",
      "description": "Stores a single health record for a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the record." },
        "uid": { "type": "string", "description": "The ID of the user who owns this record." },
        "type": { "type": "string", "description": "The type of health record (e.g., Blood Pressure, Weight)." },
        "value": { "type": "string", "description": "The value of the measurement." },
        "unit": { "type": "string", "description": "The unit of measurement." },
        "date": { "type": "string", "format": "date-time", "description": "The timestamp of the measurement." },
        "notes": { "type": "string", "description": "Optional notes for the record." }
      },
      "required": ["id", "uid", "type", "value", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document."
    },
    "/users/{userId}/records/{recordId}": {
      "schema": "HealthRecord",
      "description": "Individual health records for a user."
    }
  }
}
